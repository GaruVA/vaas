# ═══════════════════════════════════════════════════════════════════════════════
# VAAS — Environment configuration template
#
# SETUP INSTRUCTIONS
# ------------------
#   1. Copy this file:   copy .env.example .env
#   2. Edit .env and fill in every value marked  ← CHANGE THIS
#   3. Never commit .env to version control (it is in .gitignore)
#   4. Restart serve.py after any change here
# ═══════════════════════════════════════════════════════════════════════════════


# ── Security ─────────────────────────────────────────────────────────────────
# Flask session signing key.  Must be a long, random string in production.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
VAAS_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32      # ← CHANGE THIS


# ── Hardware mode ─────────────────────────────────────────────────────────────
# LIVE  — real webcams + real Arduino barrier (production)
# MOCK  — no cameras, no Arduino; MJPEG stream shows placeholder (testing only)
VAAS_HW_MODE=LIVE


# ── Arduino Nano (barrier controller) ────────────────────────────────────────
# Windows serial port.  Check Device Manager → Ports (COM & LPT).
# Linux equivalent: /dev/ttyUSB0  or  /dev/ttyACM0
VAAS_ARDUINO_PORT=COM3


# ── Webcam indices (DirectShow / V4L2) ────────────────────────────────────────
# Run `python -c "import cv2; [print(i, cv2.VideoCapture(i).isOpened()) for i in range(4)]"`
# to list which indices are valid on this machine.
VAAS_CAM_A=0          # USB camera assigned to GATE_A
VAAS_CAM_B=1          # USB camera assigned to GATE_B


# ── Gate directions ───────────────────────────────────────────────────────────
# Physical mounting: which side of the gate does each camera face?
VAAS_GATE_A_DIR=ENTRY
VAAS_GATE_B_DIR=EXIT


# ── Web server ────────────────────────────────────────────────────────────────
VAAS_HOST=0.0.0.0     # 0.0.0.0 = accessible from LAN; 127.0.0.1 = localhost only
VAAS_PORT=5000
VAAS_THREADS=32       # Waitress thread pool — 32 threads handles 2×MJPEG + SSE + HTTP concurrently


# ── Advanced / optional ────────────────────────────────────────────────────────
# These have good defaults and rarely need changing.

# VAAS_PLATE_CONF=0.70          # YOLOv8 plate-detection confidence threshold
# VAAS_CHAR_CONF=0.65           # YOLOv8 character-classifier confidence threshold
# VAAS_DEBOUNCE_SECS=15         # Seconds to suppress repeat plate events
# VAAS_EXCEPTION_TIMEOUT=30     # Seconds before unattended visitor auto-rejects
# VAAS_SESSION_HOURS=8          # Web session idle timeout (hours)
